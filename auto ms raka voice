detectBtn.MouseButton1Click:Connect(function()
    detectOn = not detectOn
    if detectOn then
        detectBtn.Text = "🔍 Detect Player: ON"
        detectBtn.TextColor3 = C.green
        pcall(function()
            local hrp = lp.Character:FindFirstChild("HumanoidRootPart")
            detectPart = Instance.new("Part")
            detectPart.Size = Vector3.new(detectRadius/15, detectRadius/10, detectRadius/15)
            detectPart.Anchored = true
            detectPart.CanCollide = false
            detectPart.CanTouch = false
            detectPart.CanQuery = false
            detectPart.Transparency = detectTransp
            detectPart.BrickColor = BrickColor.new("Bright red")
            detectPart.CastShadow = false
            detectPart.CFrame = hrp.CFrame
            detectPart.Parent = workspace
        end)
        -- Update posisi part tiap frame tanpa weld
        task.spawn(function()
            while detectOn and detectPart do
                local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if hrp then detectPart.CFrame = hrp.CFrame end
                task.wait(0.05)
            end
        end)
        local detecting = false
        local prevPos = nil
        detectConn = RS.Heartbeat:Connect(function()
            local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            if not detecting then
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= lp and plr.Character then
                        local theirHRP = plr.Character:FindFirstChild("HumanoidRootPart")
                        if theirHRP then
                            local dist = (hrp.Position - theirHRP.Position).Magnitude
                            if dist < detectRadius then
                                -- Raycast cek dinding
                                local params = RaycastParams.new()
                                params.FilterDescendantsInstances = {lp.Character, plr.Character}
                                params.FilterType = Enum.RaycastFilterType.Exclude
                                local dir = theirHRP.Position - hrp.Position
                                local ray = workspace:Raycast(hrp.Position, dir, params)
                                -- Gak ada dinding = terdetect
                                if not ray then
                                    detecting = true
                                    prevPos = hrp.Position
                                    hrp.CFrame = CFrame.new(Vector3.new(510,3,600))
                                    setStatus("⚠ "..plr.Name.." deket! Nunggu pergi...",255,180,0)
                                    break
                                end
                            end
                        end
                    end
                end
            else
                if not prevPos then detecting = false; return end
                local stillThere = false
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= lp and plr.Character then
                        local closest = math.huge
                        for _, part in ipairs(plr.Character:GetChildren()) do
                            if part:IsA("BasePart") then
                                local d = (prevPos - part.Position).Magnitude
                                if d < closest then closest = d end
                            end
                        end
                        if closest < detectRadius then
                            stillThere = true
                            setStatus("⚠ Masih ada "..plr.Name.."! Nunggu...",255,100,0)
                            break
                        end
                    end
                end
                if not stillThere then
                    local hrp2 = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                    if hrp2 then hrp2.CFrame = CFrame.new(prevPos) end
                    setStatus("✓ Aman! Balik ke posisi",0,220,80)
                    prevPos = nil
                    detecting = false
                end
            end
        end)
    else
        detectBtn.Text = "🔍 Detect Player: OFF"
        detectBtn.TextColor3 = C.purp
        if detectConn then detectConn:Disconnect(); detectConn = nil end
        if detectPart then pcall(function() detectPart:Destroy() end); detectPart = nil end
    end
end)

