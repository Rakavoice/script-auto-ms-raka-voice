-- 3. NOCLIP
-- ════════════════════════════════════════
local noclipOn = false
local noclipConn = nil
local noclipCD = 0
local noclipBtn = mkBtn(194, "👻 Noclip: OFF", Color3.fromRGB(10,20,50))
noclipBtn.TextColor3 = C.cyan
noclipBtn.MouseButton1Click:Connect(function()
    noclipOn = not noclipOn
    if noclipOn then
        noclipBtn.Text = "👻 Noclip: ON"; noclipBtn.TextColor3 = C.green
        noclipConn = RS.Heartbeat:Connect(function()
            local ch = lp.Character; if not ch then return end
            local hrp = ch:FindFirstChild("HumanoidRootPart"); if not hrp then return end
            if tick() - noclipCD < 1 then return end
            local moving = UIS:IsKeyDown(Enum.KeyCode.W) or UIS:IsKeyDown(Enum.KeyCode.A)
                or UIS:IsKeyDown(Enum.KeyCode.S) or UIS:IsKeyDown(Enum.KeyCode.D)
            if not moving then return end
            local cam = workspace.CurrentCamera
            local dir = Vector3.new(0,0,0)
            if UIS:IsKeyDown(Enum.KeyCode.W) then dir = dir + Vector3.new(cam.CFrame.LookVector.X,0,cam.CFrame.LookVector.Z).Unit end
            if UIS:IsKeyDown(Enum.KeyCode.S) then dir = dir - Vector3.new(cam.CFrame.LookVector.X,0,cam.CFrame.LookVector.Z).Unit end
            if UIS:IsKeyDown(Enum.KeyCode.A) then dir = dir - Vector3.new(cam.CFrame.RightVector.X,0,cam.CFrame.RightVector.Z).Unit end
            if UIS:IsKeyDown(Enum.KeyCode.D) then dir = dir + Vector3.new(cam.CFrame.RightVector.X,0,cam.CFrame.RightVector.Z).Unit end
            if dir.Magnitude == 0 then return end
            local params = RaycastParams.new()
            params.FilterDescendantsInstances = {ch}
            params.FilterType = Enum.RaycastFilterType.Exclude
            local head = ch:FindFirstChild("Head")
            local headPos = head and head.Position or (hrp.Position + Vector3.new(0,1.5,0))
            local result = workspace:Raycast(headPos, dir.Unit * 3, params)
            if result and math.abs(result.Normal.Y) < 0.5 then
                hrp.CFrame = CFrame.new(hrp.Position + dir.Unit * 5)
                noclipCD = tick()
            end
        end)
    else
        noclipBtn.Text = "👻 Noclip: OFF"; noclipBtn.TextColor3 = C.cyan
        if noclipConn then noclipConn:Disconnect(); noclipConn = nil end
    end
end)

