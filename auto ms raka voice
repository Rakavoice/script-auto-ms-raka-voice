local function pressE()
    VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(0.1)
    VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game)
end

local function getItem(names)
    for _, name in ipairs(names) do
        local item = lp.Backpack:FindFirstChild(name) or lp.Character:FindFirstChild(name)
        if item and item:IsA("Tool") then return item end
    end
    return nil
end

local function equip(names)
    local item = getItem(names)
    if not item then return false end
    local hum = lp.Character:FindFirstChildWhichIsA("Humanoid")
    if hum then hum:EquipTool(item); task.wait(0.5) end
    return true
end

